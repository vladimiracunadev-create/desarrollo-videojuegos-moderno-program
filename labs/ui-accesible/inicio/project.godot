; Engine configuration file.
; Proyecto de referencia del laboratorio "UI accesible y localizada" del
; Programa de Desarrollo de Videojuegos Moderno.

config_version=5

[application]

config/name="UI accesible — Inicio"
config/description="Proyecto de partida del laboratorio: completa los TODO de scripts/."
run/main_scene="res://escenas/menu.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")

[autoload]

Ajustes="*res://scripts/ajustes.gd"

[display]

window/size/viewport_width=1280
window/size/viewport_height=720
; 'canvas_items' + 'expand' es la combinación que aguanta 16:9, 21:9 y 4:3 sin
; deformar: la UI se reajusta en vez de estirarse (clase 194).
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[gui]

theme/custom="res://escenas/tema.tres"

[input]

accion_principal={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":69,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[internationalization]

locale/translations=PackedStringArray("res://i18n/textos.en.translation", "res://i18n/textos.es.translation")
locale/fallback="es"
